#!/usr/bin/env bash

set -Eeuo pipefail

KAT_ROOT="${KAT_ROOT:-/opt/karelia-admin-toolkit}"
VERSION_FILE="$KAT_ROOT/VERSION"

if [[ -f "$VERSION_FILE" ]]; then
    KAT_VERSION="$(cat "$VERSION_FILE")"
else
    KAT_VERSION="dev"
fi

show_help() {
    cat <<USAGE
Karelia Admin Toolkit $KAT_VERSION

Usage:
  kat <action> <target> [options]
  kat fleet plan zabbix-agent2 hosts.txt
  kat doctor
  kat inventory
  kat menu

Actions:
  install              Install component
  status               Show component status
  update               Update installed components
  configure            Configure installed components
  test                 Test checks and UserParameters
  remove               Remove component, if implemented
  fleet                Fleet operations
  doctor               Run host health checks
  inventory            Show basic host inventory
  cleanup              Linux cleanup helpers
  menu                 Interactive menu
  version              Show version
  help                 Show help

Targets:
  zabbix-agent2        Zabbix Agent2 module

Examples:
  kat doctor
  kat status zabbix-agent2
  sudo kat install zabbix-agent2 --major 6.4
  sudo kat update zabbix-agent2 --major 6.4 --dry-run
  sudo kat configure zabbix-agent2
  kat test zabbix-agent2
  kat fleet plan zabbix-agent2 hosts.txt

Compatibility:
  sudo kat zabbix-update --major 6.4 --dry-run
  kat zabbix-test
USAGE
}

module_path() {
    local target="$1"
    local action="$2"
    echo "$KAT_ROOT/modules/$target/$action.sh"
}

run_module() {
    local action="$1"
    local target="$2"
    shift 2 || true

    local module
    module="$(module_path "$target" "$action")"

    if [[ ! -f "$module" ]]; then
        echo "ERROR: module not found: $action $target" >&2
        echo "Expected: $module" >&2
        exit 1
    fi

    exec bash "$module" "$@"
}

run_doctor() {
    run_module status doctor "$@"
}

run_zabbix_update() {
    local module="$KAT_ROOT/modules/zabbix-agent2/update.sh"
    if [[ -f "$module" ]]; then
        exec bash "$module" "$@"
    fi
    exec "$KAT_ROOT/linux/zabbix/update_agent2.sh" "$@"
}

run_zabbix_install() {
    local module="$KAT_ROOT/modules/zabbix-agent2/install.sh"
    if [[ -f "$module" ]]; then
        exec bash "$module" "$@"
    fi
    exec "$KAT_ROOT/linux/zabbix/update_agent2.sh" "$@"
}

run_zabbix_configure() {
    exec "$KAT_ROOT/linux/zabbix/update_agent2.sh" --configure-only "$@"
}

run_zabbix_test() {
    local module="$KAT_ROOT/modules/zabbix-agent2/test.sh"
    if [[ -f "$module" ]]; then
        exec bash "$module"
    fi

    local keys=(
        service.zabbix_agent2.status
        copyfail.kernel.running
        copyfail.algif_aead.loaded
        copyfail.algif_aead.blocked
        copyfail.reboot.required
        copyfail.pkg.kernel
    )

    if ! command -v zabbix_agent2 >/dev/null 2>&1; then
        echo "ERROR: zabbix_agent2 not found" >&2
        exit 1
    fi

    for key in "${keys[@]}"; do
        zabbix_agent2 -t "$key"
    done
}

run_fleet() {
    local subcmd="${1:-}"
    local target="${2:-}"
    shift 2 || true

    case "$subcmd:$target" in
        plan:zabbix-agent2)
            exec bash "$KAT_ROOT/modules/fleet/plan-zabbix-agent2.sh" "$@"
            ;;
        *)
            echo "Usage: kat fleet plan zabbix-agent2 hosts.txt" >&2
            exit 1
            ;;
    esac
}

show_inventory() {
    echo "Hostname : $(hostname -f 2>/dev/null || hostname)"
    if [[ -r /etc/os-release ]]; then
        . /etc/os-release
        echo "OS       : ${PRETTY_NAME:-unknown}"
    fi
    echo "Kernel   : $(uname -r)"
    echo "Arch     : $(uname -m)"
    echo "Uptime   : $(uptime -p 2>/dev/null || uptime)"
}

show_menu() {
    while true; do
        cat <<MENU

Karelia Admin Toolkit $KAT_VERSION

1. Doctor
2. Status Zabbix Agent2
3. Install Zabbix Agent2
4. Update Zabbix Agent2
5. Configure Zabbix Agent2 UserParameters
6. Test Zabbix Agent2 keys
7. Inventory
8. Show version
9. Exit
MENU
        read -r -p "Select: " choice
        case "$choice" in
            1) run_doctor ;;
            2) run_module status zabbix-agent2 ;;
            3) run_zabbix_install ;;
            4) run_zabbix_update ;;
            5) run_zabbix_configure ;;
            6) run_zabbix_test ;;
            7) show_inventory ;;
            8) echo "$KAT_VERSION" ;;
            9) exit 0 ;;
            *) echo "Unknown option" ;;
        esac
    done
}

require_target() {
    local target="${1:-}"
    if [[ -z "$target" ]]; then
        echo "ERROR: target required" >&2
        show_help
        exit 1
    fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
    install|status|update|configure|test|remove)
        target="${1:-}"
        require_target "$target"
        shift || true
        case "$cmd:$target" in
            install:zabbix-agent2) run_zabbix_install "$@" ;;
            update:zabbix-agent2) run_zabbix_update "$@" ;;
            configure:zabbix-agent2) run_zabbix_configure "$@" ;;
            test:zabbix-agent2) run_zabbix_test "$@" ;;
            *) run_module "$cmd" "$target" "$@" ;;
        esac
        ;;
    fleet) run_fleet "$@" ;;
    doctor) run_doctor "$@" ;;
    inventory) show_inventory ;;
    cleanup) echo "cleanup module is not implemented yet" ;;
    menu) show_menu ;;
    zabbix-update) run_zabbix_update "$@" ;;
    zabbix-test) run_zabbix_test ;;
    version|--version|-v) echo "$KAT_VERSION" ;;
    help|--help|-h) show_help ;;
    *) echo "Unknown command: $cmd" >&2; show_help; exit 1 ;;
esac
